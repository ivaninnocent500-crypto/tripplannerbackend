# Copy this file to .env and fill in real values before running locally.
# Never commit the real .env file — it should be in .gitignore.

# Port the server listens on (Render/Railway/Fly.io set this automatically
# in production; only needed for local development).
PORT=3000

# Shared secret protecting the admin-only endpoints (GET /api/inquiries,
# PATCH /api/inquiries/:id/status). Generate a long random string, e.g.:
#   openssl rand -hex 32
ADMIN_API_KEY=replace_with_a_long_random_string

# Optional: restrict CORS to a specific origin (e.g. an admin web dashboard
# domain). Leave unset to allow all origins, which is fine since mobile
# app requests don't rely on CORS the way browser requests do.
# ALLOWED_ORIGIN=https://your-admin-dashboard.example.com

# Optional: override the SQLite file location. Defaults to ./data.sqlite
# relative to the backend folder. On Render/Railway/Fly.io, point this at
# a mounted persistent volume path so data survives redeploys.
# DB_PATH=/data/inquiries.sqlite
